{
  "name": "@aws/aws-s3-catalog-module-for-backstage",
  "description": "Dynamic-plugin wrapper for Backstage AWS S3 catalog discovery.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "github:awslabs/backstage-plugins-for-aws",
    "directory": "plugins/core/catalog-aws-s3"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts"
  },
  "backstage": {
    "role": "backend-plugin-module",
    "pluginId": "catalog",
    "pluginPackage": "@backstage/plugin-catalog-backend"
  },
  "scripts": {
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "clean": "backstage-cli package clean",
    "export-dynamic": "rhdh-cli plugin export --embed-package @backstage/plugin-catalog-backend-module-aws",
    "export-dynamic:clean": "yarn export-dynamic --clean"
  },
  "dependencies": {
    "@backstage/plugin-catalog-backend-module-aws": "0.4.24"
  },
  "devDependencies": {
    "@backstage/cli": "^0.35.4",
    "@red-hat-developer-hub/cli": "latest"
  },
  "files": [
    "dist"
  ]
}
